// Alka Program: Purify_1070Ti
// Goal: Move LLM weights from NVMe to VRAM via sliding window

REQUIRE ivyb_pascal.alkavl;

CLAIM GPU_MAIN;
CLAIM NVME_BOOT;

LIMIT GPU_MAIN.THERMAL MAX 85C;

SHIFT GPU_MAIN.DATA_PLANE @ 0;
FLOW NVME_BOOT[OFFSET_1] GPU_MAIN.DATA_PLANE[0] 256MB;
FENCE GPU_MAIN.METAPAGE == 1;

SHIFT GPU_MAIN.DATA_PLANE @ 256MB;
FLOW NVME_BOOT[OFFSET_2] GPU_MAIN.DATA_PLANE[0] 256MB;
FENCE GPU_MAIN.METAPAGE == 2;

SHIFT GPU_MAIN.DATA_PLANE @ 512MB;
FLOW NVME_BOOT[OFFSET_3] GPU_MAIN.DATA_PLANE[0] 256MB;
FENCE GPU_MAIN.METAPAGE == 3;

SHIFT GPU_MAIN.DATA_PLANE @ 768MB;
FLOW NVME_BOOT[OFFSET_4] GPU_MAIN.DATA_PLANE[0] 144MB;
FENCE GPU_MAIN.METAPAGE == 4;

SYNC L3;
SIGNAL INFERENCE_COMPLETE;
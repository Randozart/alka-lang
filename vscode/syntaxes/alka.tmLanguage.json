{
  "scopeName": "source.alka",
  "patterns": [
    {
      "name": "comment.line.double-slash.alka",
      "match": "//.*$"
    },
    {
      "name": "comment.block.alka",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "keyword.other.substrate.alka",
      "match": "\\b(OSSIFY|BOND|STILL|RESONATE|OSCILLATE|IMC_HIJACK|OCCUPY|COALESCE)\\b"
    },
    {
      "name": "keyword.other.safety.alka",
      "match": "\\b(FENCE|SYNC|YIELD|ISOLATE)\\b"
    },
    {
      "name": "keyword.other.diagnostic.alka",
      "match": "\\b(SENSE|SIGNAL|ECHO|PROBE_BUS|SEARCH|TRACE|WATCH)\\b"
    },
    {
      "name": "keyword.other.testing.alka",
      "match": "\\b(DRY_RUN|MOCK|PROVE)\\b"
    },
    {
      "name": "keyword.other.flux.alka",
      "match": "\\b(FOSSILIZE|QUENCH|VOID|CLONE|FLUX|ENQUEUE)\\b"
    },
    {
      "name": "keyword.control.alka",
      "match": "\\b(LET|IF|ELSE|FOR|WHILE|IN|SEQUENCE|ON|AT)\\b"
    },
    {
      "name": "keyword.other.sovereignty.alka",
      "match": "\\b(CLAIM|STAKE|VOUCH|DELEGATE|LIMIT)\\b"
    },
    {
      "name": "keyword.other.solvent.alka",
      "match": "\\b(FLOW|SHIFT|TRANSVERSE|SCATTER|DISTILL|MOLT)\\b"
    },
    {
      "name": "keyword.other.dissolution.alka",
      "match": "\\b(STRIKE|GHOST|HIJACK|VEIL|WHISPER)\\b"
    },
    {
      "name": "keyword.other.pulse.alka",
      "match": "\\b(PULSE|RHYTHM|STASIS|DRIFT)\\b"
    },
    {
      "name": "keyword.other.antidote.alka",
      "match": "\\b(SNAP|REVERT|AUDIT|VERIFY|GUARD)\\b"
    },
    {
      "name": "keyword.other.forging.alka",
      "match": "\\b(RECAST|FORGE|CRYSTALLIZE|OVERCLOCK|ABDUCT|SNOOP)\\b"
    },
    {
      "name": "variable.other.constant.alka",
      "match": "\\b([A-Z_][A-Z0-9_]*)\\b"
    },
    {
      "name": "constant.numeric.alka",
      "match": "\\b(0x[0-9A-Fa-f]+|\\d+)\\b"
    },
    {
      "name": "string.quoted.double.alka",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "keyword.operator.alka",
      "match": "[=<>!+\\-*/&|%^]+"
    },
    {
      "name": "punctuation.definition.alka",
      "match": "[(){}\\[\\],;:]"
    }
  ]
}
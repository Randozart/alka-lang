{
  "name": "alka-lang",
  "displayName": "Alka Language",
  "description": "The Officina - Alka hardware instruction set for (sub-)kernel manipulation",
  "version": "0.1.0",
  "publisher": "alka-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "icon": "assets/alka-logo.svg",
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "contributes": {
    "languages": [
      {
        "id": "alka",
        "aliases": [
          "Alka",
          "alka"
        ],
        "extensions": [
          ".alka",
          ".azoth"
        ],
        "icon": {
          "light": "assets/alka-icon.svg",
          "dark": "assets/alka-icon.svg"
        },
        "configuration": "./alka.configuration.json"
      },
      {
        "id": "alkavl",
        "aliases": [
          "Alka Vial",
          "alkavl"
        ],
        "extensions": [".alkavl"],
        "icon": {
          "light": "assets/alka-icon.svg",
          "dark": "assets/alka-icon.svg"
        },
        "configuration": "./alkavl.configuration.json"
      },
      {
        "id": "alkas",
        "aliases": [
          "Alka Binary",
          "alkas"
        ],
        "extensions": [".alkas"],
        "icon": {
          "light": "assets/alka-icon.svg",
          "dark": "assets/alka-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "alka",
        "scopeName": "source.alka",
        "path": "./syntaxes/alka.tmLanguage.json"
      },
      {
        "language": "alkavl",
        "scopeName": "source.alkavl",
        "path": "./syntaxes/alkavl.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Alka Officina",
        "uiTheme": "vs-dark",
        "path": "./themes/officina-dark.json"
      }
    ],
    "tokenColors": [
      {
        "scope": "source.alka",
        "settings": {
          "foreground": "#E0E0E0"
        }
      }
    ]
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.16.0"
  }
}